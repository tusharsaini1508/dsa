class Solution:
    def isAnagram(self, s: str, t: str) -> bool:

        # Different lengths = can never be anagram, exit early
        if len(s) != len(t):
            return False                  # ← was 'false' (wrong!) now 'False' ✅

        # Two empty scoreboards
        count_s = {}
        count_t = {}

        # Count every letter in s
        # Example: "rat" → {'r':1, 'a':1, 't':1}
        for char in s:
            count_s[char] = count_s.get(char, 0) + 1

        # Count every letter in t
        # Example: "car" → {'c':1, 'a':1, 'r':1}
        for char in t:
            count_t[char] = count_t.get(char, 0) + 1

        # If both scoreboards are identical → anagram
        # {'r':1,'a':1,'t':1} == {'c':1,'a':1,'r':1} → False ❌
        return count_s == count_t


