# ══════════════════════════════════════════════════════════════
#  COMMON MISTAKES
# ══════════════════════════════════════════════════════════════
#
#  Mistake 1: Dono skip ek saath try nahi karna
#  Mistake 1: Not trying BOTH skip options
#
#      return isPalin(l+1, r)   ← sirf left skip try kiya
#                                  only tried skipping left → WRONG
#
#      return isPalin(l+1, r) or isPalin(l, r-1)  ← SAHI / CORRECT
#
# ──────────────────────────────────────────────────────────────
#
#  Mistake 2: Mismatch na mile toh False return karna
#  Mistake 2: Returning False when no mismatch found
#
#      while l < r:
#          if s[l] != s[r]: return isPalin(...)
#          l += 1; r -= 1
#      return False   ← GALAT! No mismatch = already palindrome = True
#                        WRONG!
#
#      return True    ← SAHI / CORRECT
#
