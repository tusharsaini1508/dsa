class Solution:
    def productExceptSelf(self, nums: list[int]) -> list[int]:

        # ----------------------------------------------------------
        # WHAT IS THIS PROBLEM?
        # Given [1, 2, 3, 4]
        # Return [24, 12, 8, 6]
        #
        # answer[0] = 2×3×4 = 24  (everything EXCEPT index 0)
        # answer[1] = 1×3×4 = 12  (everything EXCEPT index 1)
        # answer[2] = 1×2×4 = 8   (everything EXCEPT index 2)
        # answer[3] = 1×2×3 = 6   (everything EXCEPT index 3)
        #
        # TRICK: for any index i,
        #   answer[i] = (product of all numbers to the LEFT of i)
        #             × (product of all numbers to the RIGHT of i)
        # ----------------------------------------------------------

        # store the length of the input list
        # nums = [1, 2, 3, 4]  →  n = 4
        n = len(nums)

        # create output array filled with 1s
        # we use 1 because we will MULTIPLY into this array later
        # starting with 0 would destroy everything (anything × 0 = 0)
        # think of it as "I haven't multiplied anything yet" = 1
        # answer = [1, 1, 1, 1]
        answer = [1] * n

        # ============================================================
        # PASS 1 — sweep LEFT to RIGHT
        # Goal: store the product of everything to the LEFT of index i
        # ============================================================

        # prefix = running product as we move left → right
        # starts at 1 because before index 0, there are NO numbers
        # (product of nothing = 1)
        prefix = 1

        for i in range(n):      # i goes 0, 1, 2, 3

            # STEP 1: store current prefix into answer[i]
            # at this moment, prefix holds the product of all numbers
            # that came BEFORE index i (to the left)
            answer[i] = prefix

            # STEP 2: now update prefix to include nums[i]
            # so the NEXT index gets a prefix that includes this number
            prefix = prefix * nums[i]

            # ⚠️ ORDER MATTERS — we save first, then update
            # if we updated prefix BEFORE saving, answer[i] would
            # accidentally include nums[i] itself — which we don't want

        # let's trace through the full loop:
        #
        # i=0: answer[0] = 1        (nothing to the left of index 0)
        #      prefix = 1 × 1 = 1
        #
        # i=1: answer[1] = 1        (only nums[0]=1 is to the left, 1=1)
        #      prefix = 1 × 2 = 2
        #
        # i=2: answer[2] = 2        (nums[0]×nums[1] = 1×2 = 2 to the left)
        #      prefix = 2 × 3 = 6
        #
        # i=3: answer[3] = 6        (nums[0]×nums[1]×nums[2] = 1×2×3 = 6)
        #      prefix = 6 × 4 = 24
        #
        # after pass 1 → answer = [1, 1, 2, 6]
        # each slot now holds the LEFT product for that index

        # ============================================================
        # PASS 2 — sweep RIGHT to LEFT
        # Goal: multiply answer[i] by the product of everything to
        #       the RIGHT of index i
        # after this, answer[i] = left product × right product
        #                       = product of everything except nums[i]
        # ============================================================

        # suffix = running product as we move right → left
        # starts at 1 because after the last index, there are NO numbers
        # (product of nothing = 1)
        suffix = 1

        # range(n-1, -1, -1) counts DOWN: 3, 2, 1, 0
        # range( start=n-1, stop=-1, step=-1 )
        # stop is -1 because range stops BEFORE the stop value,
        # so it includes 0 but not -1
        for i in range(n - 1, -1, -1):     # i goes 3, 2, 1, 0

            # STEP 1: multiply the suffix (right product) into answer[i]
            # answer[i] already has the LEFT product from pass 1
            # now we bake in the RIGHT product too
            # answer[i] = left_product × right_product  ✓
            answer[i] = answer[i] * suffix

            # STEP 2: update suffix to include nums[i]
            # so the NEXT index (going left) gets a suffix that
            # includes this number
            suffix = suffix * nums[i]

            # ⚠️ ORDER MATTERS again — multiply into answer first,
            # THEN update suffix
            # if we updated suffix first, answer[i] would include
            # nums[i] on the right side too — which we don't want

        # let's trace through the full loop:
        # (answer currently = [1, 1, 2, 6] from pass 1)
        #
        # i=3: answer[3] = 6 × 1  = 6     (nothing to the right of index 3)
        #      suffix = 1 × 4 = 4
        #
        # i=2: answer[2] = 2 × 4  = 8     (only nums[3]=4 is to the right)
        #      suffix = 4 × 3 = 12
        #
        # i=1: answer[1] = 1 × 12 = 12    (nums[2]×nums[3] = 3×4 = 12)
        #      suffix = 12 × 2 = 24
        #
        # i=0: answer[0] = 1 × 24 = 24    (nums[1]×nums[2]×nums[3] = 2×3×4 = 24)
        #      suffix = 24 × 1 = 24
        #
        # after pass 2 → answer = [24, 12, 8, 6]  ✓

        # ============================================================
        # FINAL PICTURE — both passes together
        #
        # nums         =  [ 1,   2,   3,   4  ]
        #
        # left product =  [ 1,   1,   2,   6  ]   (pass 1)
        # right product=  [ 24,  12,  4,   1  ]   (pass 2 suffix values)
        #
        # answer       =  [ 1×24, 1×12, 2×4, 6×1 ]
        #              =  [ 24,   12,   8,   6   ]  ✓
        #
        # TIME  COMPLEXITY: O(n) — two loops, each touching n elements
        # SPACE COMPLEXITY: O(1) — only two extra variables (prefix, suffix)
        #                          the output array doesn't count as extra
        # ============================================================

        return answer
